{
	admin off
	persist_config off
	auto_https off
	log {
		format json
	}
	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:3000} {
	log {
		format json
	}

	# Vite build: index.html + assets/
	root * dist

	encode gzip

	handle /health {
		respond "ok" 200
	}

	handle {
		route {
			try_files {path} /index.html
			file_server
		}
	}
}
