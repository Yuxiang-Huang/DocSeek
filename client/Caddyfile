# Reference: https://docs.railway.com/guides/react#use-a-dockerfile
{
	admin off
	persist_config off
	auto_https off
	log {
		format json
	}
	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:3000} {
	log {
		format json
	}

	# Static files live here (Dockerfile copies dist/client → ./dist)
	root * dist

	encode gzip

	handle /health {
		respond "ok" 200
	}

	# try_files must run before file_server so missing paths (e.g. /, /results) rewrite to the SPA shell
	handle {
		route {
			try_files {path} /_shell.html
			file_server
		}
	}
}
